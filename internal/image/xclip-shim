#!/bin/sh
# xclip shim — bridges to host clipboard via claustro TCP or Unix socket.
# Handles the argument patterns used by Claude Code's image paste.
#
# On macOS hosts: clipboard server listens on TCP; port is in clipboard.port.
# On Linux hosts: clipboard server listens on a Unix socket.
SOCK=/run/claustro/clipboard.sock
PORT_FILE=/run/claustro/clipboard.port

# Determine connection method: TCP (macOS host) or Unix socket (Linux host).
if [ -f "$PORT_FILE" ]; then
    PORT=$(cat "$PORT_FILE")
    BASE="http://host.docker.internal:${PORT}"
    CURL_OPTS=""
elif [ -S "$SOCK" ]; then
    BASE="http://localhost"
    CURL_OPTS="--unix-socket $SOCK"
else
    exit 1
fi

TARGET=""
OUTPUT=0

while [ $# -gt 0 ]; do
    case "$1" in
        -selection)
            shift  # consume the value (e.g. "clipboard")
            ;;
        -t|-target)
            shift
            TARGET="$1"
            ;;
        -o|-out)
            OUTPUT=1
            ;;
    esac
    shift
done

[ "$OUTPUT" -eq 1 ] || exit 0

case "$TARGET" in
    TARGETS)
        curl -sf $CURL_OPTS "${BASE}/types"
        ;;
    image/*)
        curl -sf $CURL_OPTS "${BASE}/image/png"
        ;;
    text/*)
        curl -sf $CURL_OPTS "${BASE}/text"
        ;;
    *)
        curl -sf $CURL_OPTS "${BASE}/types"
        ;;
esac
