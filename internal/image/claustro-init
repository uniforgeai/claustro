#!/bin/sh
# claustro-init — container startup script (runs as root)
#
# 1. Creates the host-path symlink so Claude Code uses the same
#    ~/.claude/projects/ entry as the host session.
# 2. Hands off to the sandbox user.

set -e

HOST_PATH="${CLAUSTRO_HOST_PATH:-}"

if [ -n "$HOST_PATH" ]; then
    # Create the directory tree up to (but not including) the final component
    parent="$(dirname "$HOST_PATH")"
    if [ ! -d "$parent" ]; then
        mkdir -p "$parent"
        chown sandbox:sandbox "$parent"
    fi

    # Create the symlink if it doesn't exist
    if [ ! -e "$HOST_PATH" ]; then
        ln -sf /workspace "$HOST_PATH"
        chown -h sandbox:sandbox "$HOST_PATH"
    fi
fi

# Allow the sandbox user to reach the SSH agent socket.
# On macOS the relay socket (/run/host-services/ssh-auth.sock) is owned by the
# macOS host uid (501) with mode 0660; the sandbox user (uid 1000) has no access.
# chmod 666 while still root gives all container users read/write on the socket
# without affecting the socket semantics.
if [ -n "${SSH_AUTH_SOCK:-}" ] && [ -S "$SSH_AUTH_SOCK" ]; then
    chmod 666 "$SSH_AUTH_SOCK" 2>/dev/null || true
fi

# Allow the sandbox user to access the clipboard bridge socket directory.
# The directory is bind-mounted from the host (owned by the host uid, not uid 1000).
# chmod 777 lets the sandbox user traverse the directory and connect to clipboard.sock.
if [ -d /run/claustro ]; then
    chmod 777 /run/claustro 2>/dev/null || true
fi

# Hand off to sandbox user, running the provided command
exec su -s /bin/sh sandbox -c "$(printf '%s ' "$@")"
